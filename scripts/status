#!/usr/bin/env bash
set -euo pipefail

# ─── Autoship Status Dashboard ─────────────────────────────────────
# Queries the HTTP API + workspace directory to show a live dashboard.
#
# Usage:
#   scripts/status              # Default: http://localhost:4800
#   scripts/status --port 9000  # Custom port
# ───────────────────────────────────────────────────────────────────

# ─── Colors ─────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ─── Parse Args ─────────────────────────────────────────────────────
PORT=4800
WORKSPACE_ROOT="$HOME/code/autoship-workspaces"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --port) PORT="$2"; shift 2 ;;
    --workspace-root) WORKSPACE_ROOT="$2"; shift 2 ;;
    -h|--help)
      cat <<'EOF'
Usage: scripts/status [options]

Options:
  --port N              HTTP API port (default: 4800)
  --workspace-root DIR  Workspace directory (default: ~/code/autoship-workspaces)

EOF
      exit 0
      ;;
    *) shift ;;
  esac
done

API_URL="http://localhost:${PORT}/api/v1/state"

echo -e "${BOLD}═══ Autoship Status Dashboard ═══${NC}"
echo ""

# ─── Try HTTP API ───────────────────────────────────────────────────
API_DATA=""
if command -v curl &>/dev/null; then
  API_DATA=$(curl -s --max-time 3 "$API_URL" 2>/dev/null || echo "")
fi

if [[ -n "$API_DATA" && "$API_DATA" != "" ]]; then
  RUNNING_COUNT=$(echo "$API_DATA" | jq -r '.runningCount // 0' 2>/dev/null || echo "0")
  MAX_CONCURRENT=$(echo "$API_DATA" | jq -r '.maxConcurrent // "?"' 2>/dev/null || echo "?")
  TOTAL_INPUT=$(echo "$API_DATA" | jq -r '.totals.inputTokens // 0' 2>/dev/null || echo "0")
  TOTAL_OUTPUT=$(echo "$API_DATA" | jq -r '.totals.outputTokens // 0' 2>/dev/null || echo "0")
  TOTAL_SECONDS=$(echo "$API_DATA" | jq -r '.totals.secondsRunning // 0' 2>/dev/null || echo "0")
  RETRYING_COUNT=$(echo "$API_DATA" | jq -r '.retrying | length' 2>/dev/null || echo "0")

  echo -e "${GREEN}Running:${NC} ${RUNNING_COUNT}/${MAX_CONCURRENT} agents  ${YELLOW}Retrying:${NC} ${RETRYING_COUNT}"
  echo -e "${DIM}Tokens: ${TOTAL_INPUT} in / ${TOTAL_OUTPUT} out | Runtime: ${TOTAL_SECONDS}s${NC}"
  echo ""

  # Show running agents
  RUNNING_IDS=$(echo "$API_DATA" | jq -r '.running | keys[]' 2>/dev/null || true)
  if [[ -n "$RUNNING_IDS" ]]; then
    echo -e "${BOLD}Running Agents:${NC}"
    while IFS= read -r id; do
      IDENT=$(echo "$API_DATA" | jq -r ".running[\"$id\"].identifier // \"?\"" 2>/dev/null)
      STARTED=$(echo "$API_DATA" | jq -r ".running[\"$id\"].startedAt // \"?\"" 2>/dev/null)
      TOKENS=$(echo "$API_DATA" | jq -r ".running[\"$id\"].session.totalTokens // 0" 2>/dev/null)
      TURNS=$(echo "$API_DATA" | jq -r ".running[\"$id\"].session.turnCount // 0" 2>/dev/null)
      LAST_EVENT=$(echo "$API_DATA" | jq -r ".running[\"$id\"].session.lastEvent // \"?\"" 2>/dev/null)

      # Calculate elapsed
      if [[ "$STARTED" != "?" ]]; then
        START_EPOCH=$(date -j -f "%Y-%m-%dT%H:%M:%S" "${STARTED%%.*}" +%s 2>/dev/null || echo "0")
        NOW_EPOCH=$(date +%s)
        ELAPSED_MIN=$(( (NOW_EPOCH - START_EPOCH) / 60 ))
        ELAPSED_STR="${ELAPSED_MIN}min"
      else
        ELAPSED_STR="?"
      fi

      TOKENS_K=$(echo "scale=1; $TOKENS / 1000" | bc 2>/dev/null || echo "$TOKENS")

      echo -e "  ${CYAN}${IDENT}${NC}: ${LAST_EVENT} (${ELAPSED_STR}, ${TOKENS_K}k tokens, ${TURNS} turns)"
    done <<< "$RUNNING_IDS"
    echo ""
  fi

  # Show retrying
  RETRY_IDS=$(echo "$API_DATA" | jq -r '.retrying | keys[]' 2>/dev/null || true)
  if [[ -n "$RETRY_IDS" ]]; then
    echo -e "${BOLD}Retrying:${NC}"
    while IFS= read -r id; do
      IDENT=$(echo "$API_DATA" | jq -r ".retrying[\"$id\"].identifier // \"?\"" 2>/dev/null)
      ATTEMPT=$(echo "$API_DATA" | jq -r ".retrying[\"$id\"].attempt // \"?\"" 2>/dev/null)
      ERROR=$(echo "$API_DATA" | jq -r ".retrying[\"$id\"].error // \"none\"" 2>/dev/null)
      echo -e "  ${YELLOW}${IDENT}${NC}: attempt #${ATTEMPT} (${ERROR})"
    done <<< "$RETRY_IDS"
    echo ""
  fi
else
  echo -e "${YELLOW}API not reachable at ${API_URL}${NC}"
  echo -e "${DIM}(Start autoship or check --port)${NC}"
  echo ""
fi

# ─── Workspace Status ──────────────────────────────────────────────
if [[ -d "$WORKSPACE_ROOT" ]]; then
  TOTAL_WS=0
  HEALTHY_WS=0
  BROKEN_WS=0

  for ws in "$WORKSPACE_ROOT"/*/; do
    [[ -d "$ws" ]] || continue
    TOTAL_WS=$((TOTAL_WS + 1))
    if [[ -d "${ws}.git" ]]; then
      HEALTHY_WS=$((HEALTHY_WS + 1))
    else
      BROKEN_WS=$((BROKEN_WS + 1))
    fi
  done

  echo -e "${BOLD}Workspaces:${NC} ${GREEN}${HEALTHY_WS} healthy${NC}, ${RED}${BROKEN_WS} broken${NC} (${TOTAL_WS} total in ${WORKSPACE_ROOT})"

  # Show workspace details
  if [[ $TOTAL_WS -gt 0 ]]; then
    for ws in "$WORKSPACE_ROOT"/*/; do
      [[ -d "$ws" ]] || continue
      WS_NAME=$(basename "$ws")
      if [[ -d "${ws}.git" ]]; then
        BRANCH=$(cd "$ws" && git branch --show-current 2>/dev/null || echo "?")
        COMMITS=$(cd "$ws" && git log origin/main..HEAD --oneline 2>/dev/null | wc -l | tr -d ' ')
        HAS_PR="no"
        if command -v gh &>/dev/null; then
          PR_CHECK=$(cd "$ws" && gh pr list --head "$BRANCH" --json number --jq '.[0].number' 2>/dev/null || echo "")
          [[ -n "$PR_CHECK" ]] && HAS_PR="#${PR_CHECK}"
        fi
        echo -e "  ${CYAN}${WS_NAME}${NC}: branch=${BRANCH} commits=${COMMITS} pr=${HAS_PR}"
      else
        echo -e "  ${RED}${WS_NAME}${NC}: ${RED}NO .git (broken)${NC}"
      fi
    done
  fi
else
  echo -e "${DIM}Workspace dir not found: ${WORKSPACE_ROOT}${NC}"
fi

echo ""
echo -e "${GREEN}✓ Status check complete${NC}"
